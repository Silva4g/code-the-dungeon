                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "",
                  "pm.test('Room has chest object', () => {",
                  "  const objects = pm.response.json().objects;",
                  "  pm.expect(objects).to.be.an('array').with.lengthOf(1);",
                  "  pm.expect(objects[0].type).to.eql('chest');",
                  "});",
                  "",
                  "pm.test('Chest contains Iron Key', () => {",
                  "  const chest = pm.response.json().objects[0];",
                  "  pm.expect(chest.contains).to.be.an('array');",
                  "  pm.expect(chest.contains[0].name).to.eql('Iron Key');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /room/fake-room — Not found (404)",
          "request": {
