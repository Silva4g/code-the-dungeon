{
  "info": {
    "name": "Dungeon Backend API",
    "description": "Collection completa para validar todas as fases do Dungeon Backend.\n\nVariáveis:\n- {{base_url}}: URL base da API (default: http://localhost:3001/api)\n- {{player_id}}: ID do player criado (setado automaticamente)\n- {{player_name}}: Nome do player\n\nOrdem de execução recomendada:\n1. Health Check\n2. Phase 1 (Player + Room)\n3. Phase 2 (Combat)\n4. Phase 3 (Inventory)\n5. Phase 4 (World)\n\nUse o Collection Runner para rodar tudo de uma vez.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:3001/api" },
    { "key": "player_id", "value": "" },
    { "key": "player_name", "value": "TestHero" }
  ],
  "item": [
    {
      "name": "Health Check",
      "item": [
        {
          "name": "GET /health",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/health"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "",
                  "pm.test('Response has status ok', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.status).to.eql('ok');",
                  "});",
                  "",
                  "pm.test('Response has phase number', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.phase).to.be.a('number');",
                  "});",
                  "",
                  "pm.test('Response time < 200ms', () => {",
                  "  pm.expect(pm.response.responseTime).to.be.below(200);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Phase 1 — Hello Dungeon",
      "item": [
        {
          "name": "POST /player/create — Create player",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/player/create",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{player_name}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201 Created', () => pm.response.to.have.status(201));",
                  "",
                  "pm.test('Response has player fields', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('id');",
                  "  pm.expect(json).to.have.property('name');",
                  "  pm.expect(json).to.have.property('hp');",
                  "  pm.expect(json).to.have.property('max_hp');",
                  "  pm.expect(json).to.have.property('atk');",
                  "  pm.expect(json).to.have.property('def');",
                  "  pm.expect(json).to.have.property('level');",
                  "  pm.expect(json).to.have.property('xp');",
                  "});",
                  "",
                  "pm.test('Player name matches input', () => {",
                  "  pm.expect(pm.response.json().name).to.eql(pm.variables.get('player_name'));",
                  "});",
                  "",
                  "pm.test('Player starts with 100 HP', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.hp).to.eql(100);",
                  "  pm.expect(json.max_hp).to.eql(100);",
                  "});",
                  "",
                  "pm.test('Player starts at level 1 with 0 XP', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.level).to.eql(1);",
                  "  pm.expect(json.xp).to.eql(0);",
                  "});",
                  "",
                  "// Save player_id for subsequent requests",
                  "const json = pm.response.json();",
                  "if (json.id) {",
                  "  pm.collectionVariables.set('player_id', json.id);",
                  "  console.log('Saved player_id:', json.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /player/create — Missing name (400)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/player/create",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400 Bad Request', () => pm.response.to.have.status(400));",
                  "",
                  "pm.test('Response has error message', () => {",
                  "  pm.expect(pm.response.json()).to.have.property('error');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /player/create — Empty name (400)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/player/create",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"   \"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400 for whitespace-only name', () => pm.response.to.have.status(400));",
                  "",
                  "pm.test('Response has error message', () => {",
                  "  pm.expect(pm.response.json()).to.have.property('error');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /player/:id — Get created player",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/player/{{player_id}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "",
                  "pm.test('Returns correct player', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.id).to.eql(pm.collectionVariables.get('player_id'));",
                  "  pm.expect(json.name).to.eql(pm.variables.get('player_name'));",
                  "});",
                  "",
                  "pm.test('Player has all required fields', () => {",
                  "  const json = pm.response.json();",
                  "  const fields = ['id','name','hp','max_hp','atk','def','level','xp'];",
                  "  fields.forEach(f => pm.expect(json).to.have.property(f));",
                  "});",
                  "",
                  "pm.test('HP and stats are numbers', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.hp).to.be.a('number');",
                  "  pm.expect(json.atk).to.be.a('number');",
                  "  pm.expect(json.def).to.be.a('number');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /player/:id — Unknown player (404)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/player/nonexistent-player-999"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 404', () => pm.response.to.have.status(404));",
                  "",
                  "pm.test('Response has error field', () => {",
                  "  pm.expect(pm.response.json()).to.have.property('error');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /room/room-1 — Entrance Hall",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/room/room-1"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "",
                  "pm.test('Room has correct id and name', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.id).to.eql('room-1');",
                  "  pm.expect(json.name).to.eql('Entrance Hall');",
                  "});",
                  "",
                  "pm.test('Room has biome', () => {",
                  "  pm.expect(pm.response.json().biome).to.eql('catacombs');",
                  "});",
                  "",
                  "pm.test('Room has dimensions', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.width).to.be.a('number').and.above(0);",
                  "  pm.expect(json.depth).to.be.a('number').and.above(0);",
                  "});",
                  "",
                  "pm.test('Room has exits array', () => {",
                  "  const exits = pm.response.json().exits;",
                  "  pm.expect(exits).to.be.an('array');",
                  "  pm.expect(exits.length).to.be.above(0);",
                  "});",
                  "",
                  "pm.test('Exit has required fields', () => {",
                  "  const exit = pm.response.json().exits[0];",
                  "  pm.expect(exit).to.have.property('id');",
                  "  pm.expect(exit).to.have.property('direction');",
                  "  pm.expect(exit).to.have.property('target_room');",
                  "  pm.expect(exit).to.have.property('locked');",
                  "});",
                  "",
                  "pm.test('Room has enemies array', () => {",
                  "  pm.expect(pm.response.json().enemies).to.be.an('array');",
                  "});",
                  "",
                  "pm.test('Room has loot array', () => {",
                  "  const loot = pm.response.json().loot;",
                  "  pm.expect(loot).to.be.an('array');",
                  "  pm.expect(loot.length).to.eql(1);",
                  "});",
                  "",
                  "pm.test('Loot item has correct structure', () => {",
                  "  const item = pm.response.json().loot[0];",
                  "  pm.expect(item.id).to.eql('loot-1');",
                  "  pm.expect(item.name).to.eql('Rusty Sword');",
                  "  pm.expect(item.type).to.eql('weapon');",
                  "  pm.expect(item.rarity).to.eql('common');",
                  "});",
                  "",
                  "pm.test('Room has map coordinates', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('map_x');",
                  "  pm.expect(json).to.have.property('map_y');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /room/room-2 — Room with enemies",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/room/room-2"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "",
                  "pm.test('Room has 2 enemies', () => {",
                  "  const enemies = pm.response.json().enemies;",
                  "  pm.expect(enemies).to.be.an('array').with.lengthOf(2);",
                  "});",
                  "",
                  "pm.test('Enemy has combat stats', () => {",
                  "  const enemy = pm.response.json().enemies[0];",
                  "  pm.expect(enemy).to.have.property('id');",
                  "  pm.expect(enemy).to.have.property('name');",
                  "  pm.expect(enemy).to.have.property('hp');",
                  "  pm.expect(enemy).to.have.property('max_hp');",
                  "  pm.expect(enemy).to.have.property('atk');",
                  "  pm.expect(enemy).to.have.property('def');",
                  "  pm.expect(enemy).to.have.property('xp');",
                  "});",
                  "",
                  "pm.test('Room has 3 exits including locked door', () => {",
                  "  const exits = pm.response.json().exits;",
                  "  pm.expect(exits).to.have.lengthOf(3);",
                  "  const locked = exits.find(e => e.locked === true);",
                  "  pm.expect(locked).to.not.be.undefined;",
                  "  pm.expect(locked.direction).to.eql('north');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /room/room-3 — Room with objects",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/room/room-3"
          },
          "event": [
            {
              "listen": "test",
              "script": {
