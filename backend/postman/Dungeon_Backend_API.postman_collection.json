                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Phase 2 — Combat",
      "item": [
        {
          "name": "POST /combat/attack — Attack enemy",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/combat/attack",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"player_id\": \"{{player_id}}\",\n  \"target_id\": \"enemy-1\",\n  \"weapon_id\": null\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const status = pm.response.code;",
                  "",
                  "if (status === 501) {",
                  "  pm.test('Phase 2 not implemented yet (501)', () => {",
                  "    pm.expect(status).to.eql(501);",
                  "    console.log('⏭️  Skip — implement POST /combat/attack');",
                  "  });",
                  "} else {",
                  "  pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "",
                  "  pm.test('Response has damage field', () => {",
                  "    pm.expect(pm.response.json()).to.have.property('damage');",
                  "    pm.expect(pm.response.json().damage).to.be.a('number').and.above(0);",
                  "  });",
                  "",
                  "  pm.test('Response has is_crit boolean', () => {",
                  "    pm.expect(pm.response.json().is_crit).to.be.a('boolean');",
                  "  });",
                  "",
                  "  pm.test('Response has target HP', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('target_hp');",
                  "    pm.expect(json).to.have.property('target_max_hp');",
                  "    pm.expect(json.target_hp).to.be.at.most(json.target_max_hp);",
                  "  });",
                  "",
                  "  pm.test('Response has killed boolean', () => {",
                  "    pm.expect(pm.response.json().killed).to.be.a('boolean');",
                  "  });",
                  "",
                  "  pm.test('Response has message', () => {",
                  "    pm.expect(pm.response.json().message).to.be.a('string');",
                  "  });",
                  "}"
                ]
              }
            }
          ]
        },
